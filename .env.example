# App Store Connect API credentials
# Create a key at: App Store Connect → Users and Access → Integrations → App Store Connect API
# See docs/SETUP.md for the full walkthrough.

# Key ID (short alphanumeric, shown next to the key)
ASC_KEY_ID=

# Issuer ID (UUID, shown at the top of the Integrations page)
ASC_ISSUER_ID=

# Provide the .p8 private key ONE of these three ways:

# 1) Absolute path to the downloaded .p8 file (simplest)
ASC_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

# 2) ...or the raw PEM contents (keep the newlines)
# ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 3) ...or base64 of the .p8 file (no newline headaches):  base64 -i AuthKey_XXXX.p8
# ASC_PRIVATE_KEY_BASE64=

# Optional: default Vendor Number for sales/finance reports (8–9 digits).
# Found in App Store Connect → Payments and Financial Reports (or Sales and Trends).
# Sales/finance/analytics reports also require a key with the Admin, Finance, or
# Sales role — an App Manager key cannot read them.
# ASC_VENDOR_NUMBER=
